# Copia este archivo a .env y completa tus valores reales.
# (.env está ignorado por git para no exponer credenciales.)

# Base de datos MySQL (la usa Prisma)
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BASE_DATOS
DATABASE_URL="mysql://root:tu_password@localhost:3306/prospecta"

# La GOOGLE_PLACES_API_KEY se guarda automáticamente en .env.local
# la primera vez que abras la app. También puedes ponerla aquí manualmente:
# GOOGLE_PLACES_API_KEY="tu_clave_aqui"

# --- Autenticación (Auth.js / NextAuth v5) ---
# Secreto para firmar las sesiones (JWT). Genéralo con:  npx auth secret
# (o:  openssl rand -base64 32). Ponlo en .env.local, NO lo subas a git.
AUTH_SECRET="genera_un_secreto_aleatorio"

# Usuario administrador por defecto que crea el seed (npm run db:seed)
# si la tabla de usuarios está vacía. Cámbialo tras el primer inicio de sesión.
DEFAULT_ADMIN_EMAIL="erick.cantillo97@gmail.com"
DEFAULT_ADMIN_PASSWORD="prospecta123"
